# Firebase (client) — Project settings → Your apps → Web
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin
# Local dev: path to service account file (gitignored)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Vercel/production: paste full JSON from firebase-service-account.json (do NOT use PATH on Vercel)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"aauc-site",...}
# Do not paste JSON into FIREBASE_SERVICE_ACCOUNT_PATH — that var is a file path only.

# Site URL (production: https://your-domain.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Paystack
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Email: stub | firebase_extension
EMAIL_PROVIDER=stub
FIREBASE_MAIL_COLLECTION=mail
